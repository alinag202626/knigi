## Полное решение для приложения «Book Tracker»


### Шаг 1. Создание GUI‑формы

Используем библиотеку `tkinter` для интерфейса:

```python
import tkinter as tk
from tkinter import ttk, messagebox
import json
import os

class BookTracker:
    def __init__(self, root):
        self.root = root
        self.root.title("Book Tracker")
        self.root.geometry("800x600")

        # Загрузка книг
        self.books = []
        self.load_books()

        self.create_widgets()

    def create_widgets(self):
        # Фрейм для добавления книг
        add_frame = ttk.LabelFrame(self.root, text="Добавить книгу")
        add_frame.grid(row=0, column=0, padx=10, pady=10, sticky="ew")

        # Название книги
        ttk.Label(add_frame, text="Название книги:").grid(row=0, column=0, padx=5, pady=5, sticky="w")
        self.title_entry = ttk.Entry(add_frame, width=40)
        self.title_entry.grid(row=0, column=1, padx=5, pady=5)

        # Автор
        ttk.Label(add_frame, text="Автор:").grid(row=1, column=0, padx=5, pady=5, sticky="w")
        self.author_entry = ttk.Entry(add_frame, width=40)
        self.author_entry.grid(row=1, column=1, padx=5, pady=5)

        # Жанр
        ttk.Label(add_frame, text="Жанр:").grid(row=2, column=0, padx=5, pady=5, sticky="w")
        self.genre_entry = ttk.Combobox(add_frame, values=[
            "Фантастика", "Детектив", "Роман", "Биография", "Поэзия",
            "Научная литература", "Приключения", "Фэнтези", "Классика", "Другое"
        ])
        self.genre_entry.grid(row=2, column=1, padx=5, pady=5)

        # Количество страниц
        ttk.Label(add_frame, text="Количество страниц:").grid(row=3, column=0, padx=5, pady=5, sticky="w")
        self.pages_entry = ttk.Entry(add_frame, width=40)
        self.pages_entry.grid(row=3, column=1, padx=5, pady=5)

        # Кнопка добавления
        ttk.Button(add_frame, text="Добавить книгу", command=self.add_book).grid(
            row=4, column=0, columnspan=2, pady=10
        )

        # Фрейм для фильтрации
        filter_frame = ttk.LabelFrame(self.root, text="Фильтрация")
        filter_frame.grid(row=1, column=0, padx=10, pady=10, sticky="ew")

        ttk.Label(filter_frame, text="По жанру:").grid(row=0, column=0, padx=5, pady=5, sticky="w")
        self.filter_genre = ttk.Combobox(filter_frame, values=["Все"] + [
            "Фантастика", "Детектив", "Роман", "Биография", "Поэзия",
            "Научная литература", "Приключения", "Фэнтези", "Классика", "Другое"
        ])
        self.filter_genre.set("Все")
        self.filter_genre.grid(row=0, column=1, padx=5, pady=5)

        ttk.Label(filter_frame, text="Страниц больше:").grid(row=0, column=2, padx=5, pady=5, sticky="w")
        self.filter_pages = ttk.Entry(filter_frame, width=15)
        self.filter_pages.insert(0, "0")
        self.filter_pages.grid(row=0, column=3, padx=5, pady=5)

        ttk.Button(filter_frame, text="Применить фильтр", command=self.apply_filter).grid(
            row=0, column=4, padx=5, pady=5
        )
        ttk.Button(filter_frame, text="Сбросить фильтр", command=self.reset_filter).grid(
            row=0, column=5, padx=5, pady=5
        )

        # Таблица книг
        table_frame = ttk.LabelFrame(self.root, text="Список книг")
        table_frame.grid(row=2, column=0, padx=10, pady=10, sticky="nsew")

        columns = ("Название", "Автор", "Жанр", "Страниц")
        self.tree = ttk.Treeview(table_frame, columns=columns, show="headings", height=15)
        for col in columns:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=180)
        self.tree.grid(row=0, column=0, sticky="nsew")

        # Полоса прокрутки
        scrollbar = ttk.Scrollbar(table_frame, orient="vertical", command=self.tree.yview)
        scrollbar.grid(row=0, column=1, sticky="ns")
        self.tree.configure(yscrollcommand=scrollbar.set)

        # Настройка весов для растягивания
        self.root.grid_rowconfigure(2, weight=1)
        self.root.grid_columnconfigure(0, weight=1)
        table_frame.grid_rowconfigure(0, weight=1)
        table_frame.grid_columnconfigure(0, weight=1)

        # Обновление таблицы
        self.update_table()
```

### Шаг 2. Функции добавления и валидации

```python
    def add_book(self):
        title = self.title_entry.get().strip()
        author = self.author_entry.get().strip()
        genre = self.genre_entry.get().strip()
        pages_str = self.pages_entry.get().strip()

        # Валидация ввода
        if not title or not author or not genre:
            messagebox.showerror("Ошибка", "Название, автор и жанр не могут быть пустыми!")
            return

        try:
            pages = int(pages_str)
            if pages <= 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Ошибка", "Количество страниц должно быть положительным числом!")
            return

        # Добавление книги
        book = {
            "title": title,
            "author": author,
            "genre": genre,
            "pages": pages
        }
        self.books.append(book)
        self.save_books()
        self.update_table()

        # Очистка полей ввода
        self.title_entry.delete(0, tk.END)
        self.author_entry.delete(0, tk.END)
        self.genre_entry.set("")
        self.pages_entry.delete(0, tk.END)

        messagebox.showinfo("Успех", "Книга добавлена в коллекцию!")
```

### Шаг 3. Фильтрация данных

```python
    def apply_filter(self):
        selected_genre = self.filter_genre.get()
        selected_pages_str = self.filter_pages.get().strip()

        filtered = self.books

        # Фильтр по жанру
        if selected_genre != "Все":
            filtered = [b for b in filtered if b["genre"] == selected_genre]

        # Фильтр по количеству страниц
        if selected_pages_str:
            try:
                min_pages = int(selected_pages_str)
                filtered = [b for b in filtered if b["pages"] >= min_pages]
            except ValueError:
                messagebox.showerror("Ошибка", "Минимальное количество страниц должно быть числом!")
                return

        self.update_table(filtered)

    def reset_filter(self):
        self.filter_genre.set("Все")
        self.filter_pages.delete(0, tk.END)
        self.filter_pages.insert(0, "0")
        self.update_table()
```

### Шаг 4. Сохранение и загрузка данных в JSON

```python
    def save_books(self):
        with
    def save_books(self):
        try:
            with open("books.json", "w", encoding="utf-8") as f:
                json.dump(self.books, f, ensure_ascii=False, indent=2)
        except IOError as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить данные: {e}")

    def load_books(self):
        if os.path.exists("books.json"):
            try:
                with open("books.json", "r", encoding="utf-8") as f:
                    self.books = json.load(f)
            except (json.JSONDecodeError, IOError) as e:
                messagebox.showerror("Ошибка", f"Ошибка загрузки данных: {e}")
                self.books = []
        else:
            self.books = []

    def update_table(self, books_list=None):
        # Очистка таблицы
        for item in self.tree.get_children():
            self.tree.delete(item)

        # Выбор данных для отображения
        display_books = books_list if books_list is not None else self.books

        # Заполнение таблицы
        for book in display_books:
            self.tree.insert("", "end", values=(
                book["title"],
                book["author"],
                book["genre"],
                book["pages"]
            ))
